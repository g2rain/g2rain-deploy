# G2Rain部署环境变量配置示例
# 复制此文件为 .env 并修改相应配置
SPRING_PROFILES_ACTIVE=test
PLATFORM_HOST=your.server.host
PLATFORM_PORT=10443
# 平台完整访问地址（固定 https 协议）
PLATFORM_BASE_URL=https://${PLATFORM_HOST}:${PLATFORM_PORT}
# IAM 对外根地址（与 g2rain-iam 中 IAM_BASE_URL 一致）；可与上项相同。不设置时 compose 内会回退为 PLATFORM_BASE_URL。
HEALTH_APP_IMAGE=g2rain/g2rain-health-app:latest

# MySQL配置
MYSQL_ROOT_PASSWORD=g2rain123456
MYSQL_DATABASE=g2rain
MYSQL_USER=g2rain
MYSQL_PASSWORD=g2rain123456
MYSQL_PORT=3306

# Redis配置
REDIS_PORT=6379
REDIS_PASSWORD=g2rain_redis_11050826

# Nginx配置
NGINX_HTTPS_PORT=10443

#NACOS配置
# 容器内访问 Nacos 须使用 Compose「服务名」nacos，与 container_name 无关
NACOS_SERVER_ADDR=nacos:8848
NACOS_PORT=8848
NACOS_GRPC_PORT=9848
NACOS_AUTH_TOKEN=VGhyZWVGb3J0eVR3b0J5dGVzU2VjcmV0S2V5Rm9yTmFjb3M=
NACOS_AUTH_IDENTITY_KEY=nacos
NACOS_AUTH_IDENTITY_VALUE=g2rain_nacos
NACOS_NAMESPACE=g2rain-test

# NACOS独立数据库配置
NACOS_DATABASE=nacos
NACOS_MYSQL_USER=nacos
NACOS_MYSQL_PASSWORD=g2rain_nacos

# 时区设置
TZ=Asia/Shanghai
